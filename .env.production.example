# .env.production.example
#
# 📌 이 파일이 뭐냐면?
#   AWS 배포 시 실제 .env 파일을 만들 때 참고하는 양식
#   실제 값은 없어서 GitHub에 올려도 안전!
#   내일 EC2 서버에서 이 양식 보고 .env 파일 만들면 됨
#
# 📌 사용법
#   EC2 서버에서:
#   cp .env.production.example .env
#   nano .env  ← 실제 값으로 편집

PORT=8080
NODE_ENV=production

# DB 설정 (AWS RDS 또는 EC2 내 MySQL)
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASS=your-db-password
DB_NAME=brewy

# JWT (운영에선 더 복잡하게!)
JWT_SECRET=your-very-strong-secret-key-here
JWT_EXPIRES=1h
